# Horadus sprint autopilot baseline.
# Source of truth: codex/rules/default.rules in the repo.

prefix_rule(
    pattern = ["uv", "run", "--no-sync", "horadus"],
    decision = "allow",
    justification = "Allow Horadus workflow commands required by repo-owned Codex automations.",
    match = [
        "uv run --no-sync horadus tasks automation-lock check --path /Users/s5una/.codex/automations/horadus-sprint-autopilot/lock",
        "uv run --no-sync horadus tasks automation-lock lock --path /Users/s5una/.codex/automations/horadus-sprint-autopilot/lock",
        "uv run --no-sync horadus tasks automation-lock unlock --path /Users/s5una/.codex/automations/horadus-sprint-autopilot/lock",
        "uv run --no-sync horadus tasks preflight",
        "uv run --no-sync horadus tasks safe-start TASK-357 --name codex-rules-baseline",
        "uv run --no-sync horadus tasks finish TASK-357",
    ],
    not_match = [
        "uv run horadus tasks preflight",
        "uv sync",
    ],
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Allow preflight and finish working-tree state checks used by the Horadus workflow.",
    match = [
        "git status --porcelain",
    ],
    not_match = [
        "git fetch origin",
        "git rev-parse HEAD",
    ],
)

prefix_rule(
    pattern = ["git", "rev-parse"],
    decision = "allow",
    justification = "Allow branch and commit resolution used by the Horadus workflow lifecycle.",
    match = [
        "git rev-parse --abbrev-ref HEAD",
        "git rev-parse HEAD",
        "git rev-parse origin/main",
    ],
    not_match = [
        "git status --porcelain",
        "git cat-file -e deadbeef",
    ],
)

prefix_rule(
    pattern = ["git", "fetch"],
    decision = "allow",
    justification = "Allow remote sync checks required by the Horadus workflow.",
    match = [
        "git fetch origin",
        "git fetch --all --prune",
    ],
    not_match = [
        "git pull --ff-only",
        "git push origin main",
    ],
)

prefix_rule(
    pattern = ["git", "show-ref"],
    decision = "allow",
    justification = "Allow task-branch existence checks before start and cleanup after merge.",
    match = [
        "git show-ref --verify --quiet refs/heads/codex/task-357-codex-rules-baseline",
        "git show-ref --verify refs/heads/codex/task-357-codex-rules-baseline",
    ],
    not_match = [
        "git ls-remote --heads origin codex/task-357-codex-rules-baseline",
        "git branch -d codex/task-357-codex-rules-baseline",
    ],
)

prefix_rule(
    pattern = ["git", "ls-remote"],
    decision = "allow",
    justification = "Allow remote branch checks and branch-head alignment validation.",
    match = [
        "git ls-remote --exit-code --heads origin codex/task-357-codex-rules-baseline",
        "git ls-remote --heads origin codex/task-357-codex-rules-baseline",
    ],
    not_match = [
        "git fetch origin",
        "git show-ref --verify refs/heads/codex/task-357-codex-rules-baseline",
    ],
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "allow",
    justification = "Allow the workflow to create task branches and resync local main after merge.",
    match = [
        "git switch -c codex/task-357-codex-rules-baseline",
        "git switch main",
    ],
    not_match = [
        "git branch -d codex/task-357-codex-rules-baseline",
        "git pull --ff-only",
    ],
)

prefix_rule(
    pattern = ["git", "pull", "--ff-only"],
    decision = "allow",
    justification = "Allow fast-forward-only main sync before and after task work.",
    match = [
        "git pull --ff-only",
        "git pull --ff-only origin main",
    ],
    not_match = [
        "git pull",
        "git fetch origin",
    ],
)

prefix_rule(
    pattern = ["git", "cat-file"],
    decision = "allow",
    justification = "Allow post-merge verification that the merge commit exists locally.",
    match = [
        "git cat-file -e 29b9ae3ad9daa17c249e48930af2383e8afade7d",
    ],
    not_match = [
        "git rev-parse HEAD",
        "git branch -d codex/task-357-codex-rules-baseline",
    ],
)

prefix_rule(
    pattern = ["git", "branch"],
    decision = "allow",
    justification = "Allow local deletion of merged task branches after main is synced.",
    match = [
        "git branch -d codex/task-357-codex-rules-baseline",
    ],
    not_match = [
        "git switch main",
        "git push origin codex/task-357-codex-rules-baseline",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin"],
    decision = "allow",
    justification = "Allow publishing updates to task branches that already track origin.",
    match = [
        "git push origin codex/task-357-codex-rules-baseline",
    ],
    not_match = [
        "git push backup codex/task-357-codex-rules-baseline",
        "git fetch origin",
    ],
)

prefix_rule(
    pattern = ["git", "push", "-u", "origin"],
    decision = "allow",
    justification = "Allow first push of a new task branch to origin with upstream tracking.",
    match = [
        "git push -u origin codex/task-357-codex-rules-baseline",
    ],
    not_match = [
        "git push -u backup codex/task-357-codex-rules-baseline",
        "git fetch origin",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--set-upstream", "origin"],
    decision = "allow",
    justification = "Allow first push of a new task branch when git renders the long upstream flag.",
    match = [
        "git push --set-upstream origin codex/task-357-codex-rules-baseline",
    ],
    not_match = [
        "git push --set-upstream backup codex/task-357-codex-rules-baseline",
        "git fetch origin",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", "main"],
    decision = "forbidden",
    justification = "Do not push directly to main from Codex automations.",
)

prefix_rule(
    pattern = ["git", "push", "-u", "origin", "main"],
    decision = "forbidden",
    justification = "Do not publish main as a tracked branch from Codex automations.",
)

prefix_rule(
    pattern = ["git", "push", "--set-upstream", "origin", "main"],
    decision = "forbidden",
    justification = "Do not publish main as a tracked branch from Codex automations.",
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Do not allow force-pushes from Codex automations.",
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Do not allow force-pushes from Codex automations.",
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Do not allow force-pushes from Codex automations.",
)

prefix_rule(
    pattern = ["gh", "pr"],
    decision = "allow",
    justification = "Allow PR state, checks, and review status queries for the task lifecycle.",
    match = [
        "gh pr list --state open --base main --author @me",
        "gh pr view 290 --json title,body,comments",
        "gh pr checks 290",
    ],
    not_match = [
        "gh api graphql",
        "gh auth status",
    ],
)

prefix_rule(
    pattern = ["gh", "repo"],
    decision = "allow",
    justification = "Allow repository metadata lookups used by review-thread and review-refresh helpers.",
    match = [
        "gh repo view --json nameWithOwner --jq .nameWithOwner",
    ],
    not_match = [
        "gh pr view 291",
        "gh api graphql -f query=query",
    ],
)

prefix_rule(
    pattern = ["gh", "api"],
    decision = "allow",
    justification = "Allow the review-gate REST and GraphQL calls used by Horadus finish for this repo.",
    match = [
        "gh api repos/s5unanow/horadus/pulls/290/reviews",
        "gh api repos/s5unanow/horadus/pulls/290/comments",
        "gh api repos/s5unanow/horadus/issues/290/comments",
        "gh api repos/s5unanow/horadus/issues/290/reactions",
        "gh api graphql -f query=query",
        "gh api graphql -f query=mutation",
    ],
    not_match = [
        "gh pr view 290",
        "gh auth status",
    ],
)

prefix_rule(
    pattern = ["gh", "api", "--method", "PATCH"],
    decision = "forbidden",
    justification = "Do not allow repository-admin REST mutations from Codex automations.",
)

prefix_rule(
    pattern = ["gh", "api", "--method", "PUT"],
    decision = "forbidden",
    justification = "Do not allow repository-admin REST mutations from Codex automations.",
)

prefix_rule(
    pattern = ["gh", "api", "--method", "DELETE"],
    decision = "forbidden",
    justification = "Do not allow destructive REST mutations from Codex automations.",
)
